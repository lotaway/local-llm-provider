# TTS Quality Estimation Thresholds
TTS_EVAL_THRESHOLDS__WER_MAX= # Optional: Maximum Word Error Rate, default=0.08
TTS_EVAL_THRESHOLDS__DNSMOS_MIN= # Optional: Minimum DNSMOS overall score, default=3.8
TTS_EVAL_THRESHOLDS__SIMILARITY_MIN= # Optional: Minimum Speaker Similarity, default=0.78

# TTS Quality Estimation Model Configurations
TTS_EVAL_MODELS__WHISPER_MODEL= # Optional: Whisper model size (large, medium, etc.), default=large
TTS_EVAL_MODELS__DNSMOS_MODEL_PATH= # Optional: Path to DNSMOS ONNX model, default=models/dnsmos.onnx
TTS_EVAL_MODELS__ECAPA_MODEL_SOURCE= # Optional: SpeechBrain model source or path, default=speechbrain/spkrec-ecapa-voxceleb
